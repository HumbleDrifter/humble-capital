+
+def _default_test_underlying(raw: str | None) -> str:
+    symbol = str(raw or "").strip().upper()
+    if symbol:
+        return symbol
+    return "SPY"
+
+
+def _default_test_underlying_price(symbol: str) -> float:
+    defaults = {
+        "SPY": 520.0,
+        "QQQ": 450.0,
+        "AAPL": 220.0,
+    }
+    return float(defaults.get(symbol, 100.0))
+
+
+def _normalize_test_strike(symbol: str, price_hint: float) -> float:
+    """
+    Pick a simple ATM-ish strike for proposal generation.
+    This is only a test/default path and should avoid obviously invalid
+    values like the old hardcoded 100 strike for large-cap underlyings.
+    """
+    px = max(1.0, float(price_hint or 0.0))
+
+    # Keep increments simple and realistic enough for proposal generation.
+    if symbol in {"SPY", "QQQ"}:
+        increment = 1.0
+    elif px >= 500:
+        increment = 5.0
+    elif px >= 200:
+        increment = 2.5
+    elif px >= 50:
+        increment = 1.0
+    else:
+        increment = 0.5
+
+    return float(round(px / increment) * increment)
+
+
