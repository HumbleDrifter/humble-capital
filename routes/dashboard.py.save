import os
from flask import Blueprint, render_template_string, request, Response

dashboard_bp = Blueprint("dashboard", __name__)

API_SECRET = os.getenv("STATUS_SECRET") or os.getenv("WEBHOOK_SHARED_SECRET") or ""

HTML = r"""
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Trading Bot Dashboard</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style>
    :root{
      --bg:#0f1115;
      --panel:#171a21;
      --panel2:#1d2330;
      --text:#e8ecf3;
      --muted:#9aa4b2;
      --good:#19c37d;
      --warn:#f5a524;
      --bad:#f31260;
      --accent:#4f8cff;
      --accent2:#8b5cf6;
      --cash:#64748b;
      --core:#2563eb;
      --sat:#7c3aed;
      --border:#2a3140;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }
    .wrap {
      max-width: 1500px;
      margin: 0 auto;
