_PRODUCT_CACHE = {"ts": 0.0, "products": []}


def get_products_catalog(force_refresh: bool = False):
    global _PRODUCT_CACHE
    now = time.time()
    if not force_refresh and _PRODUCT_CACHE["products"] and (now - float(_PRODUCT_CACHE["ts"] or 0)) < 300:
        return list(_PRODUCT_CACHE["products"])

    client = get_client()
    products = []
    cursor = None
    while True:
        resp = _to_dict(client.get_products(limit=250, cursor=cursor) if cursor else client.get_products(limit=250))
        batch = resp.get("products", []) or resp.get("product_details", []) or []
        products.extend(batch)
        if not resp.get("has_next") or not resp.get("cursor"):
            break
        cursor = resp.get("cursor")

    cleaned = []
    for prod in products:
        item = _to_dict(prod)
        product_id = str(item.get("product_id") or item.get("id") or "").upper().strip()
        if not product_id:
            continue
        cleaned.append({
            "product_id": product_id,
            "base_currency": str(item.get("base_currency") or "").upper(),
            "quote_currency": str(item.get("quote_currency") or "").upper(),
            "status": str(item.get("status") or item.get("trading_status") or "").upper(),
            "trading_disabled": bool(item.get("trading_disabled", False)),
            "is_disabled": bool(item.get("is_disabled", False)),
            "new": bool(item.get("new", False)),
            "raw": item,
        })

    cleaned.sort(key=lambda x: x["product_id"])
    _PRODUCT_CACHE = {"ts": now, "products": cleaned}
    return list(cleaned)


def get_valid_products(quote_currency: str = "USD", tradable_only: bool = True):
    quote_currency = str(quote_currency or "USD").upper().strip()
    out = []
    for item in get_products_catalog():
        if quote_currency and item.get("quote_currency") != quote_currency:
            continue
        if tradable_only and (item.get("trading_disabled") or item.get("is_disabled")):
            continue
        out.append({k: v for k, v in item.items() if k != "raw"})
    return out


def product_exists(product_id: str) -> bool:
    product_id = str(product_id or "").upper().strip()
    if not product_id:
        return False
    for item in get_products_catalog():
        if item.get("product_id") == product_id:
            return True
    return False
