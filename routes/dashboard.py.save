<script>
const API_SECRET = {{ api_secret|tojson }};
const secretModeEl = document.getElementById('secretMode');
secretModeEl.textContent = API_SECRET ? 'configured' : 'not configured';

let LAST_MEME_TILES = [];

function authUrl(path) {
  if (!API_SECRET) return path;
  const sep = path.includes('?') ? '&' : '?';
  return `${path}${sep}secret=${encodeURIComponent(API_SECRET)}`;
}

function fmtUsd(v) {
  const n = Number(v || 0);
  return n.toLocaleString(undefined, {style:'currency', currency:'USD', maximumFractionDigits:2});
}
function fmtPct(v) {
  const n = Number(v || 0) * 100;
  return `${n.toFixed(2)}%`;
}
function fmtPctDirect(v) {
  const n = Number(v || 0);
  return `${n.toFixed(2)}%`;
}
function setUiRefresh() {
  document.getElementById('uiRefresh').textContent = new Date().toLocaleString();
}
function cacheBadge(cache) {
  if (!cache) return '<span class="badge">no-cache-meta</span>';
  const src = cache.source || 'unknown';
  if (src === 'live') return `<span class="badge good">live</span>`;
  if (src === 'fresh-cache') return `<span class="badge accent">fresh-cache</span>`;
  if (src === 'stale-cache') return `<span class="badge warn">stale-cache</span>`;
  return `<span class="badge">${src}</span>`;
}
async function fetchJson(path, opts={}) {
  const res = await fetch(authUrl(path), opts);
  const data = await res.json();
  if (!res.ok || data.ok === false) {
    const msg = data.error || `HTTP ${res.status}`;
    throw new Error(msg);
  }
  return data;
}

function scoreGradientColor(score) {
  const s = Math.max(0, Math.min(100, Number(score || 0)));
  const hue = 220 - (220 * (s / 100));
  const bg = `hsla(${hue}, 85%, 55%, 0.24)`;
  const border = `hsla(${hue}, 90%, 65%, 0.48)`;
  return { bg, border };
}

function getPortfolioSentimentScore(productId, pnl) {
  const match = (LAST_MEME_TILES || []).find(
    x => String(x.product_id || '').toUpperCase() === String(productId || '').toUpperCase()
  );

  if (match) {
    return Number(match.score || 0);
  }

  return Math.max(0, Math.min(100, ((Number(pnl || 0) + 20) / 40) * 100));
}

function renderStatusBadges(statusData, portfolioData, rebalanceData, heatmapData, memeHeatmapData, configData) {
  const el = document.getElementById('statusBadges');
  const badges = [];
  badges.push(`<span class="badge ${statusData?.ok ? 'good' : 'bad'}">service ${statusData?.ok ? 'ok' : 'error'}</span>`);
  if (portfolioData?._cache) badges.push(cacheBadge(portfolioData._cache));
  if (rebalanceData?._cache) badges.push(cacheBadge(rebalanceData._cache));
  if (heatmapData?._cache) badges.push(cacheBadge(heatmapData._cache));
  if (memeHeatmapData?._cache) badges.push(cacheBadge(memeHeatmapData._cache));
  if (configData?.config?.satellite_mode) {
    badges.push(`<span class="badge accent2">mode ${configData.config.satellite_mode}</span>`);
  }
  if (rebalanceData?.summary?.market_regime) {
    badges.push(`<span class="badge accent">regime ${rebalanceData.summary.market_regime}</span>`);
  }
  el.innerHTML = badges.join('');
}

function renderPortfolio(data) {
  const snapshot = data.snapshot || {};
  const summary = data.summary || {};
  document.getElementById('kpiTotal').textContent = fmtUsd(snapshot.total_value_usd);
  document.getElementById('kpiCash').textContent = fmtUsd(snapshot.usd_cash);
  document.getElementById('kpiCore').textContent = fmtPct(snapshot.core_weight);
  document.getElementById('kpiSat').textContent = fmtPct(snapshot.satellite_weight);

  document.getElementById('portfolioMeta').innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">positions: ${(summary.assets && Object.keys(summary.assets).length) || 0}</span>`;

  const cashW = Number(summary.cash_weight ?? snapshot.cash_weight ?? 0);
  const coreW = Number(summary.core_weight ?? snapshot.core_weight ?? 0);
  const satW = Number(summary.satellite_weight ?? snapshot.satellite_weight ?? 0);

  document.getElementById('allocationText').textContent =
    `Cash ${fmtPct(cashW)} | Core ${fmtPct(coreW)} | Satellite ${fmtPct(satW)}`;

  const segCash = document.getElementById('segCash');
  const segCore = document.getElementById('segCore');
  const segSat = document.getElementById('segSat');
  segCash.style.width = `${Math.max(0, cashW * 100)}%`;
  segCore.style.width = `${Math.max(0, coreW * 100)}%`;
  segSat.style.width = `${Math.max(0, satW * 100)}%`;
  segCash.textContent = cashW > 0.08 ? 'Cash' : '';
  segCore.textContent = coreW > 0.08 ? 'Core' : '';
  segSat.textContent = satW > 0.08 ? 'Satellite' : '';

  const cashBreakdown = summary.cash_breakdown || snapshot.cash_breakdown || {};
  document.getElementById('cashBreakdown').textContent =
`USD : ${fmtUsd(cashBreakdown.USD || 0)}
USDC: ${fmtUsd(cashBreakdown.USDC || 0)}
USDT: ${fmtUsd(cashBreakdown.USDT || 0)}
DAI : ${fmtUsd(cashBreakdown.DAI || 0)}
TOTAL: ${fmtUsd(summary.usd_cash || snapshot.usd_cash || 0)}`;

  const buyUniverse = snapshot.active_satellite_buy_universe || summary.active_satellite_buy_universe || [];
  document.getElementById('activeBuyUniverse').innerHTML =
    buyUniverse.length
      ? buyUniverse.map(x => `<span class="pill">${x}</span>`).join('')
      : '<span class="muted">None</span>';

  const tbody = document.getElementById('portfolioTable');
  const assets = Object.entries(summary.assets || {}).sort((a, b) =>
    Number((b[1] || {}).value_total_usd || 0) - Number((a[1] || {}).value_total_usd || 0)
  );

  if (!assets.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="muted">No portfolio assets available.</td></tr>';
    return;
  }

  tbody.innerHTML = assets.map(([productId, row]) => {
    const details = [];
    if (row.is_locked_or_staked) details.push('locked/staked');
    if (row.buy_eligible) details.push('buy-eligible');
    if (row.target_weight != null) details.push(`target=${Number(row.target_weight).toFixed(3)}`);
    if (row.max_weight != null) details.push(`max=${Number(row.max_weight).toFixed(3)}`);
    if (row.avg_entry_price != null && Number(row.avg_entry_price || 0) > 0) details.push(`entry=${fmtUsd(row.avg_entry_price)}`);
    if (row.unrealized_gain_pct != null) details.push(`gain=${fmtPctDirect(row.unrealized_gain_pct)}`);
    if (row.allowed_buy_usd != null) details.push(`buy=${fmtUsd(row.allowed_buy_usd)}`);
    if (row.required_trim_usd != null) details.push(`trim=${fmtUsd(row.required_trim_usd)}`);
    if (row.harvest_candidate && row.harvest_candidate.amount_usd != null) details.push(`harvest=${fmtUsd(row.harvest_candidate.amount_usd)}`);
    return `
      <tr>
        <td>${productId}</td>
        <td>${row.class || ''}</td>
        <td class="right">${fmtUsd(row.value_total_usd)}</td>
        <td class="right">${fmtPct(row.weight_total)}</td>
        <td class="right">${fmtUsd(row.price_usd || 0)}</td>
        <td>${details.join(' | ') || '<span class="muted">—</span>'}</td>
      </tr>
    `;
  }).join('');
}

function renderRebalance(data) {
  document.getElementById('rebalanceMeta').innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">preview</span>`;

  const plan = data.plan || {};
  const buys = plan.buys || [];
  const trims = plan.trims || [];
  const harvests = (data.harvest && data.harvest.harvests) || [];

  const html = `
    <div style="margin-bottom:10px;">
      <span class="badge good">buys ${buys.length}</span>
      <span class="badge warn">trims ${trims.length}</span>
      <span class="badge accent">harvests ${harvests.length}</span>
    </div>

    <div style="margin-bottom:12px;">
      <div class="tiny">Top buys</div>
      ${buys.slice(0, 5).map(x => `<div>${x.product_id}: ${fmtUsd(x.amount_usd)}</div>`).join('') || '<div class="muted">None</div>'}
    </div>

    <div style="margin-bottom:12px;">
      <div class="tiny">Top trims</div>
      ${trims.slice(0, 5).map(x => `<div>${x.product_id}: ${fmtUsd(x.amount_usd)}</div>`).join('') || '<div class="muted">None</div>'}
    </div>

    <div>
      <div class="tiny">Harvest candidates</div>
      ${harvests.slice(0, 5).map(x => `<div>${x.product_id}: ${fmtUsd(x.amount_usd)} @ ${fmtPctDirect(x.gain_pct || 0)}</div>`).join('') || '<div class="muted">None</div>'}
    </div>
  `;
  document.getElementById('rebalanceSummary').innerHTML = html;
}

function renderHeatmap(data) {
  document.getElementById('heatmapMeta').innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">assets: ${(data.heatmap?.assets || []).length}</span>`;

  const grid = document.getElementById('heatmapGrid');
  const assets = data.heatmap?.assets || [];
  if (!assets.length) {
    grid.innerHTML = '<div class="muted">No heatmap assets available.</div>';
    return;
  }

  grid.innerHTML = assets.map(a => {
    const pnl = Number(a.unrealized_pnl_pct || 0);
    const value = Number(a.value_total_usd || 0);
    const weight = Number(a.weight_total || 0);

    const sentimentScore = getPortfolioSentimentScore(a.product_id, pnl);
    const colors = scoreGradientColor(sentimentScore);

    const flags = [];
    if (a.class === 'core') flags.push('<span class="microbadge core">core</span>');
    if (a.class === 'satellite_active') flags.push('<span class="microbadge allowed">satellite</span>');
    if (a.is_candidate) flags.push('<span class="microbadge active">candidate</span>');
    if (a.is_blocked) flags.push('<span class="microbadge blocked">blocked</span>');
    if (value > 0) flags.push('<span class="microbadge held">held</span>');

    return `
      <div class="tile" style="background:${colors.bg}; border-color:${colors.border};">
        <div class="tile-top">
          <div>
            <div class="sym">${a.product_id}</div>
            <div class="small">${a.class || 'unknown'}</div>
          </div>
          <div class="score">${fmtUsd(value)}</div>
        </div>

        <div style="margin:8px 0 4px 0;">${flags.join('') || '<span class="small">no flags</span>'}</div>

        <div class="tile-grid">
          <div>
            <div class="metric-label">Weight</div>
            <div class="metric-value">${fmtPct(weight)}</div>
          </div>
          <div>
            <div class="metric-label">PnL</div>
            <div class="metric-value ${pnl >= 0 ? 'good' : 'bad'}">${fmtPctDirect(pnl)}</div>
          </div>
          <div>
            <div class="metric-label">Tier</div>
            <div class="metric-value">${a.class || 'unknown'}</div>
          </div>
          <div>
            <div class="metric-label">Score Driver</div>
            <div class="metric-value">${sentimentScore.toFixed(1)}</div>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function sortMemeTiles(tiles) {
  const sortMode = document.getElementById('memeSort')?.value || 'score';
  const out = [...tiles];

  if (sortMode === 'held') {
    out.sort((a, b) => Number(b.value_total_usd || 0) - Number(a.value_total_usd || 0));
  } else if (sortMode === 'move24h') {
    out.sort((a, b) => Number(b.price_change_24h_pct || 0) - Number(a.price_change_24h_pct || 0));
  } else if (sortMode === 'product') {
    out.sort((a, b) => String(a.product_id || '').localeCompare(String(b.product_id || '')));
  } else {
    out.sort((a, b) => {
      const scoreDiff = Number(b.score || 0) - Number(a.score || 0);
      if (scoreDiff !== 0) return scoreDiff;
      return Number(b.value_total_usd || 0) - Number(a.value_total_usd || 0);
    });
  }
  return out;
}

function renderMemeHeatmap(data) {
  const metaEl = document.getElementById('memeHeatmapMeta');
  const grid = document.getElementById('memeHeatmapGrid');

  let tiles = data?.meme_heatmap?.tiles || [];

  if (tiles.length) {
    LAST_MEME_TILES = tiles;
  } else if (LAST_MEME_TILES.length) {
    tiles = LAST_MEME_TILES;
  }

  tiles = sortMemeTiles(tiles);

  metaEl.innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">candidates: ${tiles.length}</span>` +
    ((data?.meme_heatmap?.tiles || []).length === 0 && LAST_MEME_TILES.length
      ? ` <span class="badge warn">showing last good data</span>`
      : '');

  if (!tiles.length) {
    grid.innerHTML = '<div class="muted">No meme rotation candidates available.</div>';
    return;
  }

  grid.innerHTML = tiles.map(t => {
    const score = Number(t.score || 0);
    const colors = scoreGradientColor(score);

    const flags = [];
    if (t.core) flags.push('<span class="microbadge core">core</span>');
    if (t.allowed) flags.push('<span class="microbadge allowed">allowed</span>');
    if (t.blocked) flags.push('<span class="microbadge blocked">blocked</span>');
    if (t.held) flags.push('<span class="microbadge held">held</span>');
    if (t.active_buy_universe) flags.push('<span class="microbadge active">active</span>');
    if (t.sniper_eligible) flags.push('<span class="microbadge sniper">sniper</span>');
    if (t.pump_protected) flags.push('<span class="microbadge pump">pump-protected</span>');
    if (!t.enabled) flags.push('<span class="microbadge disabled">disabled</span>');

    const move24 = Number(t.price_change_24h_pct || 0);
    const move1h = Number(t.price_change_1h_pct || 0);

    return `
      <div class="tile" style="background:${colors.bg}; border-color:${colors.border};">
        <div class="tile-top">
          <div>
            <div class="sym">${t.product_id}</div>
            <div class="small">${t.name || t.symbol || t.source || 'manual'}</div>
          </div>
          <div class="score">${score.toFixed(1)}</div>
        </div>

        <div style="margin:8px 0 4px 0;">${flags.join('') || '<span class="small">no flags</span>'}</div>

        <div class="tile-grid">
          <div>
            <div class="metric-label">Held Value</div>
            <div class="metric-value">${fmtUsd(t.value_total_usd || 0)}</div>
          </div>
          <div>
            <div class="metric-label">Weight</div>
            <div class="metric-value">${fmtPct(t.weight_total || 0)}</div>
          </div>
          <div>
            <div class="metric-label">1h Move</div>
            <div class="metric-value ${move1h >= 0 ? 'good' : 'bad'}">${fmtPctDirect(move1h)}</div>
          </div>
          <div>
            <div class="metric-label">24h Move</div>
            <div class="metric-value ${move24 >= 0 ? 'good' : 'bad'}">${fmtPctDirect(move24)}</div>
          </div>
          <div>
            <div class="metric-label">Source</div>
            <div class="metric-value">${t.source || 'manual'}</div>
          </div>
          <div>
            <div class="metric-label">Bucket</div>
            <div class="metric-value">${t.volatility_bucket || 'n/a'}</div>
          </div>
        </div>
      </div>
    `;
  }).join('');
}

function renderConfig(data) {
  const cfg = data.config || {};
  document.getElementById('configMeta').innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">mode: ${cfg.satellite_mode || 'rotation'}</span>`;

  const coreAssets = cfg.core_assets || {};
  const tbody = document.getElementById('coreAssetsTable');
  const rows = Object.entries(coreAssets).sort((a,b) => a[0].localeCompare(b[0]));
  tbody.innerHTML = rows.length
    ? rows.map(([pid, v]) => `
      <tr>
        <td>${pid}</td>
        <td>${Number(v.target_weight || 0).toFixed(3)}</td>
        <td>${Number(v.rebalance_band || 0).toFixed(3)}</td>
      </tr>
    `).join('')
    : '<tr><td colspan="3" class="muted">No core assets configured.</td></tr>';

  document.getElementById('satMode').value = cfg.satellite_mode || 'rotation';
  document.getElementById('satTotalMax').value = cfg.satellite_total_max ?? '';
  document.getElementById('satTotalTarget').value = cfg.satellite_total_target ?? '';
  document.getElementById('minCashReserve').value = cfg.min_cash_reserve ?? '';
  document.getElementById('tradeMinValueUsd').value = cfg.trade_min_value_usd ?? '';
  document.getElementById('maxQuotePerTradeUsd').value = cfg.max_quote_per_trade_usd ?? '';

  const allowed = cfg.satellite_allowed || [];
  const blocked = cfg.satellite_blocked || [];

  document.getElementById('allowedSatellites').innerHTML =
    allowed.length ? allowed.map(x => `<span class="pill">${x}</span>`).join('') : '<span class="muted">None</span>';

  document.getElementById('blockedSatellites').innerHTML =
    blocked.length ? blocked.map(x => `<span class="pill">${x}</span>`).join('') : '<span class="muted">None</span>';
}

function renderMemeRotation(data) {
  document.getElementById('memeRotationMeta').innerHTML =
    `${cacheBadge(data._cache)} <span class="tiny">updated: ${data.meme_rotation?.updated_at || 'n/a'}</span>`;

  const tbody = document.getElementById('memeRotationTable');
  const rows = data.meme_rotation?.candidates || [];
  tbody.innerHTML = rows.length
    ? rows.map(r => `
      <tr>
        <td>${r.product_id || ''}</td>
        <td>${Number(r.score || 0).toFixed(1)}</td>
        <td>${String(r.enabled ?? true)}</td>
        <td>${r.source || ''}</td>
      </tr>
    `).join('')
    : '<tr><td colspan="4" class="muted">No rotation candidates.</td></tr>';
}

function renderProducts(data) {
  document.getElementById('productsMeta').innerHTML =
    `<span class="badge accent">count ${data.count || 0}</span> <span class="tiny">quote: ${data.quote_currency || 'USD'}</span>`;

  const tbody = document.getElementById('productsTable');
  const rows = data.products || [];
  tbody.innerHTML = rows.length
    ? rows.map(r => `
      <tr>
        <td>${r.product_id || ''}</td>
        <td>${r.base_currency || ''}</td>
        <td>${r.quote_currency || ''}</td>
        <td>${r.status || ''}</td>
      </tr>
    `).join('')
    : '<tr><td colspan="4" class="muted">No products returned.</td></tr>';
}

async function saveCoreAsset() {
  const payload = {
    action: document.getElementById('coreAction').value,
    product_id: document.getElementById('coreProductId').value,
    target_weight: document.getElementById('coreTargetWeight').value,
    rebalance_band: document.getElementById('coreBand').value,
    secret: API_SECRET
  };

  await fetch(authUrl('/api/admin/asset'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  });

  await refreshAll(true);
}

async function applySatelliteChange() {
  const payload = {
    action: document.getElementById('satAction').value,
    product_id: document.getElementById('satProductId').value,
    secret: API_SECRET
  };

  await fetch(authUrl('/api/admin/asset'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  });

  await refreshAll(true);
}

async function setMode() {
  const payload = {
    action: 'set_mode',
    satellite_mode: document.getElementById('satMode').value,
    secret: API_SECRET
  };

  await fetch(authUrl('/api/admin/asset'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  });

  await refreshAll(true);
}

async function setRisk() {
  const payload = {
    action: 'set_risk',
    satellite_total_max: document.getElementById('satTotalMax').value,
    satellite_total_target: document.getElementById('satTotalTarget').value,
    min_cash_reserve: document.getElementById('minCashReserve').value,
    trade_min_value_usd: document.getElementById('tradeMinValueUsd').value,
    max_quote_per_trade_usd: document.getElementById('maxQuotePerTradeUsd').value,
    secret: API_SECRET
  };

  await fetch(authUrl('/api/admin/asset'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  });

  await refreshAll(true);
}

async function saveRotationCandidate(removeFlag) {
  const payload = {
    product_id: document.getElementById('rotationProductId').value,
    score: document.getElementById('rotationScore').value,
    enabled: document.getElementById('rotationEnabled').value,
    source: document.getElementById('rotationSource').value,
    remove: removeFlag ? 'true' : 'false',
    secret: API_SECRET
  };

  await fetch(authUrl('/api/admin/meme_rotation/candidate'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(payload)
  });

  await refreshAll(true);
}

async function loadProducts(forceRefresh) {
  const quote = document.getElementById('productQuote').value;
  const tradableOnly = document.getElementById('productTradableOnly').value;
  const data = await fetchJson(`/api/valid_products?quote=${encodeURIComponent(quote)}&tradable_only=${encodeURIComponent(tradableOnly)}&refresh=${forceRefresh ? 'true' : 'false'}`);
  renderProducts(data);
}

async function refreshCaches() {
  await fetch(authUrl('/api/admin/cache/refresh'), {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({ secret: API_SECRET })
  });

  await refreshAll(true);
}

async function refreshAll(forceProducts) {
  try {
    const [
      statusData,
      portfolioData,
      rebalanceData,
      heatmapData,
      memeHeatmapData,
      configData,
      memeRotationData
    ] = await Promise.all([
      fetchJson('/api/status'),
      fetchJson('/api/portfolio'),
      fetchJson('/api/rebalance/preview'),
      fetchJson('/api/heatmap'),
      fetchJson('/api/heatmap/meme'),
      fetchJson('/api/config'),
      fetchJson('/api/meme_rotation')
    ]);

    renderStatusBadges(statusData, portfolioData, rebalanceData, heatmapData, memeHeatmapData, configData);
    renderPortfolio(portfolioData);
    renderRebalance(rebalanceData);
    renderHeatmap(heatmapData);
    renderMemeHeatmap(memeHeatmapData);
    renderConfig(configData);
    renderMemeRotation(memeRotationData);

    if (forceProducts) {
      await loadProducts(false);
    }

    setUiRefresh();
  } catch (err) {
    console.error(err);
    document.getElementById('statusBadges').innerHTML =
      `<span class="badge bad">dashboard error: ${String(err.message || err)}</span>`;
    setUiRefresh();
  }
}

refreshAll(true);
setInterval(() => refreshAll(false), 60000);
</script>
</body>
</html>
"""

@dashboard_bp.route("/dashboard", methods=["GET"])
def dashboard():
    if API_SECRET:
      provided = request.args.get("secret", "")
      if provided != API_SECRET:
        return Response("unauthorized", status=403)

    return render_template_string(HTML, api_secret=API_SECRET)
