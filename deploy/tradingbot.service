[Unit]
Description=Humble Capital TradingBot Web App
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/root/tradingbot
EnvironmentFile=/root/tradingbot/.env
ExecStart=/usr/local/bin/gunicorn -w 3 -k gthread --threads 4 -b 127.0.0.1:8000 app:app --timeout 120
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
